// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
  engineType = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

// NextAuth Models (Simplified for Credentials, but structure supports OAuth later)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?
  image         String?
  settings      String?   // JSON string of user settings
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // App Models
  businessProfile BusinessProfile?
  knowledge       KnowledgeDocument[]
  knowledgeChunks KnowledgeChunk[]
  agents          HiredAgent[]
  history         ActivityLog[]
  automations     AutomationWorkflow[]
  projects        Project[]
  reports         Report[]
}

model BusinessProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  businessName    String?
  industry        String?
  country         String?
  businessType    String?
  employees       String?
  products        String?
  services        String?
  targetAudience  String?
  mission         String?
  vision          String?
  revenueModel    String?
  brandColors     String?
  logoUrl         String?
  website         String?
  socialMedia     String?
  goals           String?
  challenges      String?
  competitors     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model KnowledgeDocument {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  filename    String
  fileType    String   // PDF, DOCX, CSV, URL
  fileUrl     String   // Local path or cloud URL
  sizeBytes   Int      @default(0)
  status      String   @default("PROCESSING") // PROCESSING, READY, ERROR
  extractedText String? // Will store extracted knowledge

  chunks      KnowledgeChunk[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeChunk {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId  String?
  document    KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content     String
  embedding   Unsupported("vector(1536)")?
  
  createdAt   DateTime @default(now())
}

model HiredAgent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  agentId     String   // e.g., "planner", "marketing"
  name        String
  role        String
  status      String   @default("ACTIVE") // ACTIVE, PAUSED
  config      String?  // JSON string of specific configurations

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  actionType  String   // e.g., "KNOWLEDGE_UPLOADED", "AGENT_HIRED"
  description String
  agentId     String?  // If action was performed by/for a specific agent
  status      String   @default("SUCCESS")

  createdAt   DateTime @default(now())
}

model AutomationWorkflow {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  trigger     String
  action      String
  integration String
  status      String   @default("ACTIVE")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// AI Co-founder Command Center Models
// ═══════════════════════════════════════════════════════════

model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Untitled Project")
  status    String   @default("draft") // draft | running | completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks     AgentTask[]
  events    ProjectEvent[]
}

model AgentTask {
  id                 String    @id @default(cuid())
  projectId          String
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentKey           String    @default("planner") // planner | marketing | finance | operations | website
  status             String    @default("idle") // idle | queued | working | needs_review | approved
  deliverableType    String?   // e.g. "Business Plan", "Social Campaign"
  deliverableContent String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model ProjectEvent {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentKey  String?  // null = orchestrator
  message   String
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  type        String   // e.g., "Revenue", "Marketing", "Business Health"
  data        String   // JSON string of report data (e.g. chart points)
  
  createdAt   DateTime @default(now())
}

